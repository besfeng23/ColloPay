
{
  "entities": {
    "Partner": {
      "title": "Partner",
      "description": "Enterprise partner managing multiple merchants.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "INACTIVE"] },
        "apiKeyHash": { "type": "string" },
        "legalEntityName": { "type": "string" },
        "settlementAccountId": { "type": "string" }
      },
      "required": ["id", "name", "status"]
    },
    "Merchant": {
      "title": "Merchant",
      "description": "Business entity processing payments.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "partnerId": { "type": "string" },
        "name": { "type": "string" },
        "industry": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED", "INACTIVE"] },
        "externalReference": { "type": "string" },
        "defaultCurrency": { "type": "string" },
        "merchantOfRecord": { "type": "boolean" }
      },
      "required": ["id", "partnerId", "name", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "The canonical record of a payment lifecycle.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "externalReference": { "type": "string" },
        "processorTransactionId": { "type": "string" },
        "processor": { "type": "string" },
        "amountMinor": { "type": "integer" },
        "currency": { "type": "string" },
        "netAmountMinor": { "type": "integer" },
        "status": { "type": "string" },
        "reconciliationStatus": { "type": "string" }
      },
      "required": ["id", "externalReference", "amountMinor", "currency", "status"]
    },
    "TransactionTimeline": {
      "title": "Transaction Timeline",
      "description": "Immutable history of status changes for a transaction.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "transactionId": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "reason": { "type": "string" },
        "actor": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "FeeRule": {
      "title": "Fee Rule",
      "description": "Pricing configuration.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "partnerId": { "type": "string" },
        "merchantId": { "type": "string" },
        "feeType": { "type": "string", "enum": ["PERCENTAGE_BPS", "FLAT", "HYBRID"] },
        "basisPoints": { "type": "integer" },
        "flatAmountMinor": { "type": "integer" },
        "effectiveFrom": { "type": "string", "format": "date-time" }
      }
    },
    "WebhookEvent": {
      "title": "Webhook Event",
      "description": "Log of network events from processors.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "processor": { "type": "string" },
        "eventId": { "type": "string" },
        "status": { "type": "string" },
        "correlationStatus": { "type": "string" },
        "receivedAt": { "type": "string", "format": "date-time" },
        "payload": { "type": "object" }
      }
    },
    "ApprovalRequest": {
      "title": "Approval Request",
      "description": "Request for a sensitive operation that requires dual-authorization.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "operation": { "type": "string" },
        "requestedBy": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "APPROVED", "REJECTED"] },
        "payload": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/partners/{partnerId}": {
      "schema": "#/backend/entities/Partner",
      "description": "Enterprise partners."
    },
    "/merchants/{merchantId}": {
      "schema": "#/backend/entities/Merchant",
      "description": "Business merchants."
    },
    "/transactions/{transactionId}": {
      "schema": "#/backend/entities/Transaction",
      "description": "Canonical ledger."
    },
    "/transactions/{transactionId}/timeline/{eventId}": {
      "schema": "#/backend/entities/TransactionTimeline",
      "description": "Status transition history."
    },
    "/feeRules/{ruleId}": {
      "schema": "#/backend/entities/FeeRule",
      "description": "Pricing configurations."
    },
    "/webhookEvents/{eventId}": {
      "schema": "#/backend/entities/WebhookEvent",
      "description": "Network ingestion logs."
    },
    "/approvalRequests/{requestId}": {
      "schema": "#/backend/entities/ApprovalRequest",
      "description": "Dual-auth governance queue."
    }
  }
}
